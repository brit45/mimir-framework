      "name": "Base Environment",
      "data": {
        "host": "127.0.0.1",
        "port": 8088,
        "base_url": "http://{{ host }}:{{ port }}"
      }
    },
    {
      "_id": "grp_core",
      "_type": "request_group",
      "parentId": "wrk_mimir_lua_api",
      "name": "Core"
    },
    {
      "_id": "req_help",
      "_type": "request",
      "parentId": "grp_core",
      "name": "GET /help",
      "method": "GET",
      "url": "{{ base_url }}/help",
      "headers": [{ "name": "Accept", "value": "application/json" }]
    },
    {
      "_id": "req_health",
      "_type": "request",
      "parentId": "grp_core",
      "name": "GET /health",
